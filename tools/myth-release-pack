#!/data/data/com.termux/files/usr/bin/bash
set -e

KEEP="${1:-10}"

if ! [[ "$KEEP" =~ ^[0-9]+$ ]]; then
  echo "Usage:"
  echo "  myth-release-pack [keep_count]"
  echo
  echo "Example:"
  echo "  myth-release-pack 10"
  exit 1
fi

echo "========================================"
echo "   Mythology Studio Release + Pack"
echo "========================================"
echo "Keep newest snapshot zips: $KEEP"
echo

echo "[1/3] Running pipeline..."
myth-run

echo
echo "[2/3] Building repo snapshot zips..."
myth-pack "$KEEP"

echo
echo "[3/3] Pushing repos..."
myth-push

echo
echo "Release + pack complete."
echo "========================================"
