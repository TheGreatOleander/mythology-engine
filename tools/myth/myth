#!/data/data/com.termux/files/usr/bin/bash

while true; do
  clear
  echo "=================================="
  echo "        Mythology Studio"
  echo "=================================="
  echo "1) Run full pipeline"
  echo "2) Import video and run pipeline"
  echo "3) Run Mythology Engine"
  echo "4) Run Mythology Forge"
  echo "5) Run Mythology Herald"
  echo "6) Studio status"
  echo "7) Exit"
  echo ""
  read -p "Choose an option: " choice

  case "$choice" in
    1)
      myth-run
      echo ""
      read -p "Press Enter to continue..."
      ;;
    2)
      read -p "Video path: " video_path
      read -p "Title: " title
      myth-run-video "$video_path" "$title"
      echo ""
      read -p "Press Enter to continue..."
      ;;
    3)
      myth-engine
      echo ""
      read -p "Press Enter to continue..."
      ;;
    4)
      myth-forge
      echo ""
      read -p "Press Enter to continue..."
      ;;
    5)
      myth-herald
      echo ""
      read -p "Press Enter to continue..."
      ;;
    6)
      echo ""
      echo "Engine repo:   /sdcard/mythology-engine"
      echo "Forge repo:    /sdcard/mythology-forge"
      echo "Herald repo:   /sdcard/mythology-herald"
      echo ""
      echo "Engine output:"
      ls -lah /sdcard/mythology-engine/output 2>/dev/null || echo "  (missing)"
      echo ""
      echo "Forge output:"
      ls -lah /sdcard/mythology-forge/output 2>/dev/null || echo "  (missing)"
      echo ""
      echo "Herald output:"
      ls -lah /sdcard/mythology-herald/output 2>/dev/null || echo "  (missing)"
      echo ""
      read -p "Press Enter to continue..."
      ;;
    7)
      echo "Exiting Mythology Studio."
      exit 0
      ;;
    *)
      echo "Invalid option."
      sleep 1
      ;;
  esac
done
