#!/data/data/com.termux/files/usr/bin/bash

ENGINE="/sdcard/mythology-engine"
FORGE="/sdcard/mythology-forge"
HERALD="/sdcard/mythology-herald"

show_latest_dir() {
  target="$1"
  if [ -d "$target" ]; then
    latest="$(ls -1dt "$target"/* 2>/dev/null | head -n 1)"
    if [ -n "$latest" ]; then
      echo "$latest"
    else
      echo "(none)"
    fi
  else
    echo "(missing)"
  fi
}

echo "========================================"
echo "        Mythology Studio Status"
echo "========================================"
echo

echo "[Repos]"
echo "Engine : $ENGINE"
echo "Forge  : $FORGE"
echo "Herald : $HERALD"
echo

echo "[Current Outputs]"
echo "Engine output : $(show_latest_dir "$ENGINE/output")"
echo "Forge output  : $(show_latest_dir "$FORGE/output")"
echo "Herald output : $(show_latest_dir "$HERALD/output")"
echo

echo "[Archives]"
echo "Engine archive latest : $(show_latest_dir "$ENGINE/output_archive")"
echo "Forge archive latest  : $(show_latest_dir "$FORGE/output_archive")"
echo "Herald archive latest : $(show_latest_dir "$HERALD/output_archive")"
echo

echo "[Git Status]"
for repo in "$ENGINE" "$FORGE" "$HERALD"; do
  echo "---- $repo ----"
  if [ -d "$repo/.git" ]; then
    cd "$repo" || continue
    branch="$(git branch --show-current 2>/dev/null)"
    echo "Branch: ${branch:-unknown}"
    git status --short
  else
    echo "Not a git repo"
  fi
  echo
done

echo "========================================"
