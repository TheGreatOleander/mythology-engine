#!/data/data/com.termux/files/usr/bin/bash
ENGINE="/sdcard/mythology-engine"
FORGE="/sdcard/mythology-forge"
HERALD="/sdcard/mythology-herald"
latest(){ dir="$1"; if [ -d "$dir" ]; then ls -1dt "$dir"/* 2>/dev/null | head -n 1; fi; }
count(){ dir="$1"; if [ -d "$dir" ]; then ls "$dir" 2>/dev/null | wc -l; else echo "0"; fi; }
echo "========================================"
echo "        Mythology Studio Status"
echo "========================================"
echo
echo "[Current Outputs]"
echo "Engine output : $(latest "$ENGINE/output")"
echo "Forge output  : $(latest "$FORGE/output")"
echo "Herald output : $(latest "$HERALD/output")"
echo
echo "[Archives]"
echo "Engine archive latest : $(latest "$ENGINE/output_archive")"
echo "Forge archive latest  : $(latest "$FORGE/output_archive")"
echo "Herald archive latest : $(latest "$HERALD/output_archive")"
echo
echo "[Git Status]"
for repo in "$ENGINE" "$FORGE" "$HERALD"; do
  echo "---- $repo ----"
  if [ -d "$repo/.git" ]; then
    cd "$repo" || continue
    branch="$(git branch --show-current 2>/dev/null)"
    echo "Branch: ${branch:-unknown}"
    git status --short
  else
    echo "Not a git repo"
  fi
  echo
done
echo "========================================"
